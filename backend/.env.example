# Supabase 配置（在 supabase.com 项目设置 > API 中获取）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# 评委登录密码
JUDGE_PASSWORD=your_secure_password

# JWT 签名密钥（使用 openssl rand -hex 32 生成）
SECRET_KEY=your_secret_key_here

# OpenRouter LLM
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_MODEL=minimax/minimax-m2.5

# AMiner API Key
AMINER_API_KEY=your_aminer_api_key_here

# SMTP 邮件配置（用于 url_audit.py 自动发送提醒邮件）
# 常见服务商：smtp.qq.com:465 | smtp.163.com:465 | smtp.gmail.com:587
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_email@qq.com

# 报名写入性能控制
REGISTER_DB_TIMEOUT_SECONDS=4.0
REGISTER_DB_MAX_RETRIES=2
REGISTER_DB_RETRY_BASE_DELAY=0.15
REGISTER_DB_RETRY_JITTER=0.15
REGISTER_DB_MAX_CONCURRENCY=120
REGISTER_DB_QUEUE_WAIT_SECONDS=0.35

# 报名接口过载队列（可选）
REGISTER_ASYNC_QUEUE_ENABLED=true
REGISTER_ASYNC_QUEUE_MAXSIZE=3000
REGISTER_ASYNC_QUEUE_WORKERS=24
REGISTER_ASYNC_QUEUE_RETRY_LIMIT=4

# 报名截止控制
# 默认北京时间 2026-03-20 00:00:00 截止
REGISTRATION_CLOSE_AT=2026-03-20T00:00:00+08:00
REGISTRATION_FORCE_CLOSED=false
REGISTRATION_CLOSED_FLAG_FILE=./registration_closed.flag
