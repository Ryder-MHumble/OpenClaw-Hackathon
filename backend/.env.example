# Supabase 配置（在 supabase.com 项目设置 > API 中获取）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# 评委登录密码
JUDGE_PASSWORD=your_secure_password

# JWT 签名密钥（使用 openssl rand -hex 32 生成）
SECRET_KEY=your_secret_key_here

# OpenRouter LLM
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_MODEL=minimax/minimax-m2.5

# AMiner API Key
AMINER_API_KEY=your_aminer_api_key_here

# SMTP 邮件配置（用于 url_audit.py 自动发送提醒邮件）
# 常见服务商：smtp.qq.com:465 | smtp.163.com:465 | smtp.gmail.com:587
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_email@qq.com
